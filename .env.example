# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY
GROQ_API_KEY=MY_GROQ_API_KEY

# FIREBASE_API_KEY: Custom Firebase Web API key
FIREBASE_API_KEY=AIzaSyFakeKeyForUsraWellnessFirestore

# FIREBASE_APP_ID: Firebase Android Application ID
FIREBASE_APP_ID=1:62fe49071234:android:f18f4f1c957192781ab275

# FIREBASE_PROJECT_ID: Firebase Project ID
FIREBASE_PROJECT_ID=usra-harmony-wellness

# FIREBASE_WEB_CLIENT_ID: Web Client ID for Google Sign in
FIREBASE_WEB_CLIENT_ID=1064095450410-fake-client-id.apps.googleusercontent.com
